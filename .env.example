# When set to 1, .env file is ignored and only process env (e.g. Docker) is used.
# DOCKER_ENV=1

# app
APPNAME=
# port
PORT=
# swagger
SWAGGER_USERNAME=
SWAGGER_PASSWORD=
# mongoose
MONGO_URL=
# crypto js
ENCRYPTION_KEY=
# jwt
JWT_SECRET=
JWT_AccessTokenExpiry=
JWT_RefreshTokenExpiry=
# admin (first-time setup when no users exist)
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Optional: SMTP for reviewer application and other email notifications
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Committee <committee@example.com>
# MAIL_FROM=noreply@example.com